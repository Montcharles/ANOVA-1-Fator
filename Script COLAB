plt.figure(figsize=(11, 7))

x = np.arange(len(medias_plot))
y = medias_plot['mean'].values
yerr_inf = medias_plot['mean'].values - medias_plot['ic95_inf'].values
yerr_sup = medias_plot['ic95_sup'].values - medias_plot['mean'].values

bars = plt.bar(
    x, y,
    yerr=[yerr_inf, yerr_sup],
    capsize=8,
    color=sns.color_palette("Set2", len(medias_plot)),
    edgecolor='black',
    linewidth=1.2
)

for i, row in medias_plot.reset_index(drop=True).iterrows():
    plt.text(
        i,
        row['ic95_sup'] + 0.6,
        row['letra_tukey'],
        ha='center',
        va='bottom',
        fontsize=16,
        fontweight='bold'
    )

plt.xticks(x, medias_plot['tratamento'])
plt.ylabel('Redução média da pressão sistólica (mmHg)')
plt.xlabel('Tratamento')
plt.title('Redução da pressão arterial por tratamento\nMédia ± IC95% e grupos de Tukey')
plt.ylim(0, medias_plot['ic95_sup'].max() + 3)
plt.tight_layout()
plt.show()


