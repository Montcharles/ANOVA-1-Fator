# CÉLULA 17 – Função reutilizável para seus próprios dados
# O que esta célula faz:
# 1. Reúne o fluxo principal em uma função.
# 2. Permite usar o mesmo procedimento em outro experimento.
# ============================================================

def anova_1fator_completo(df, resposta, grupo, alpha=0.05):
    import numpy as np
    import pandas as pd
    import seaborn as sns
    import matplotlib.pyplot as plt
    from scipy import stats
    import statsmodels.api as sm
    from statsmodels.formula.api import ols
    from statsmodels.stats.multicomp import pairwise_tukeyhsd
    import pingouin as pg

    print("\n============================")
    print("ANÁLISE COMPLETA – ANOVA 1 FATOR")
    print("============================\n")

    # Descritiva
    desc = df.groupby(grupo)[resposta].agg(['count', 'mean', 'std', 'median', 'min', 'max']).reset_index()
    desc['se'] = desc['std'] / np.sqrt(desc['count'])
    desc['ic95_inf'] = desc['mean'] - 1.96 * desc['se']
    desc['ic95_sup'] = desc['mean'] + 1.96 * desc['se']

    print("Tabela descritiva:")
    display(desc.round(3))

    # Gráfico exploratório
    plt.figure(figsize=(10, 6))
    sns.boxplot(data=df, x=grupo, y=resposta, palette='Set3')
    sns.stripplot(data=df, x=grupo, y=resposta, color='black', alpha=0.5, jitter=True)
    plt.title('Distribuição dos dados por grupo')
    plt.tight_layout()
    plt.show()

    # Modelo
    formula = f'{resposta} ~ C({grupo})'
    modelo = ols(formula, data=df).fit()
    residuos = modelo.resid

    # Premissas
    print("Shapiro-Wilk:", stats.shapiro(residuos))
    grupos_lista = [g[resposta].values for _, g in df.groupby(grupo)]
    print("Levene:", stats.levene(*grupos_lista))

    # ANOVA
    anova = sm.stats.anova_lm(modelo, typ=2)
    print("\nTabela ANOVA:")
    display(anova)

    # Efeito
    print("\nTamanho de efeito:")
    display(pg.anova(data=df, dv=resposta, between=grupo, detailed=True))

    # Tukey
    tukey = pairwise_tukeyhsd(endog=df[resposta], groups=df[grupo], alpha=alpha)
    print("\nTukey:")
    print(tukey.summary())

    tukey_df = pd.DataFrame(tukey._results_table.data[1:], columns=tukey._results_table.data[0])
    tukey_df['p-adj'] = tukey_df['p-adj'].astype(float)
    tukey_df['meandiff'] = tukey_df['meandiff'].astype(float)
    tukey_df['lower'] = tukey_df['lower'].astype(float)
    tukey_df['upper'] = tukey_df['upper'].astype(float)
    tukey_df['reject'] = tukey_df['reject'].astype(bool)

    medias_plot = desc[[grupo, 'mean', 'se', 'ic95_inf', 'ic95_sup']].copy()
    medias_plot = medias_plot.sort_values('mean')

    def gerar_letras_tukey_local(tukey_df, medias_df, grupo_col, media_col='mean'):
        grupos = medias_df.sort_values(media_col)[grupo_col].tolist()
        sig = pd.DataFrame(False, index=grupos, columns=grupos)

        for _, row in tukey_df.iterrows():
            g1 = row['group1']
            g2 = row['group2']
            rj = bool(row['reject'])
            sig.loc[g1, g2] = rj
            sig.loc[g2, g1] = rj

        letras_disponiveis = list("abcdefghijklmnopqrstuvwxyz")
        letras_grupos = {g: "" for g in grupos}
        conjuntos = []

        for g in grupos:
            colocado = False
            for i, conjunto in enumerate(conjuntos):
                pode_entrar = True
                for membro in conjunto:
                    if sig.loc[g, membro] == True:
                        pode_entrar = False
                        break
                if pode_entrar:
                    conjunto.append(g)
                    letras_grupos[g] += letras_disponiveis[i]
                    colocado = True
            if not colocado:
                conjuntos.append([g])
                letras_grupos[g] += letras_disponiveis[len(conjuntos)-1]

        for g in grupos:
            for i, conjunto in enumerate(conjuntos):
                letra = letras_disponiveis[i]
                if letra in letras_grupos[g]:
                    continue
                pode_entrar = True
                for membro in conjunto:
                    if sig.loc[g, membro] == True:
                        pode_entrar = False
                        break
                if pode_entrar:
                    letras_grupos[g] += letra

        return letras_grupos

    letras = gerar_letras_tukey_local(tukey_df, medias_plot, grupo_col=grupo, media_col='mean')
    medias_plot['letra_tukey'] = medias_plot[grupo].map(letras)

    print("\nTabela final com letras:")
    display(medias_plot.round(3))

    # Gráfico final
    plt.figure(figsize=(11, 7))
    x = np.arange(len(medias_plot))
    y = medias_plot['mean'].values
    yerr_inf = medias_plot['mean'].values - medias_plot['ic95_inf'].values
    yerr_sup = medias_plot['ic95_sup'].values - medias_plot['mean'].values

    plt.bar(
        x, y,
        yerr=[yerr_inf, yerr_sup],
        capsize=8,
        color=sns.color_palette("Set2", len(medias_plot)),
        edgecolor='black'
    )

    for i, row in medias_plot.reset_index(drop=True).iterrows():
        plt.text(
            i,
            row['ic95_sup'] + 0.05 * max(y),
            row['letra_tukey'],
            ha='center',
            va='bottom',
            fontsize=16,
            fontweight='bold'
        )

    plt.xticks(x, medias_plot[grupo])
    plt.xlabel(grupo)
    plt.ylabel(resposta)
    plt.title(f'{resposta} por {grupo}\nMédia ± IC95% e letras de Tukey')
    plt.tight_layout()
