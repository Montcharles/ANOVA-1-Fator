sns.set_theme(style='whitegrid', context='talk')
np.random.seed(42)


# ============================================================
# CÉLULA 2 – Construção do banco de dados
# O que esta célula faz:
# 1. Cria um exemplo de estudo com 4 tratamentos.
# 2. Cada valor representa a redução da pressão sistólica (mmHg).
# 3. Esse será o exemplo principal para a ANOVA 1 fator.
# ============================================================

placebo   = [2, 4, 3, 5, 1, 4, 2, 3, 4, 2, 5, 3]
farmaco_A = [7, 8, 6, 9, 7, 8, 10, 6, 7, 9, 8, 7]
farmaco_B = [10, 11, 9, 12, 10, 11, 13, 9, 10, 12, 11, 10]
farmaco_C = [14, 15, 13, 16, 14, 15, 17, 13, 14, 16, 15, 14]

df = pd.DataFrame({
    'tratamento': (['Placebo']*12 +
                   ['Fármaco A']*12 +
                   ['Fármaco B']*12 +
                   ['Fármaco C']*12),
    'reducao_pressao': placebo + farmaco_A + farmaco_B + farmaco_C
})

print("Visualização inicial do banco de dados:")
display(df.head())
print("\nTamanho total da amostra:", len(df))


# ============================================================
# CÉLULA 3 – Estatística descritiva
# O que esta célula faz:
# 1. Resume cada grupo em uma tabela.
# 2. Mostra n, média, desvio padrão, mediana, mínimo, máximo.
# 3. Calcula erro-padrão e IC95% da média.
# ============================================================

desc = df.groupby('tratamento')['reducao_pressao'].agg(
    ['count', 'mean', 'std', 'median', 'min', 'max']
).reset_index()

desc['se'] = desc['std'] / np.sqrt(desc['count'])
desc['ic95_inf'] = desc['mean'] - 1.96 * desc['se']
desc['ic95_sup'] = desc['mean'] + 1.96 * desc['se']

print("Tabela descritiva por tratamento:")
display(desc.round(3))

print("""
INTERPRETAÇÃO DA TABELA DESCRITIVA:
- count  = número de observações no grupo
- mean   = média do grupo
- std    = desvio padrão (dispersão)
- median = mediana
- min    = menor valor
- max    = maior valor
- se     = erro padrão da média
- ic95_inf / ic95_sup = intervalo de confiança de 95% da média
""")


# ============================================================
# CÉLULA 4 – Gráfico exploratório
# O que esta célula faz:
# 1. Mostra boxplot por grupo.
# 2. Sobrepõe os pontos individuais.
# 3. Ajuda a inspecionar dispersão, tendência central e outliers.
# ============================================================

plt.figure(figsize=(11, 6))
sns.boxplot(data=df, x='tratamento', y='reducao_pressao', palette='Set2')
sns.stripplot(data=df, x='tratamento', y='reducao_pressao',
              color='black', alpha=0.6, jitter=True)
plt.title('Redução da pressão arterial por tratamento')
plt.xlabel('Tratamento')
plt.ylabel('Redução da pressão sistólica (mmHg)')
plt.tight_layout()
plt.show()


# ============================================================
# CÉLULA 5 – Definição das hipóteses
# O que esta célula faz:
# 1. Explica a hipótese nula e alternativa da ANOVA.
# ============================================================

print("""
HIPÓTESES DA ANOVA DE 1 FATOR

Hipótese nula (H0):
As médias populacionais de todos os grupos são iguais.
H0: μPlacebo = μFármacoA = μFármacoB = μFármacoC

Hipótese alternativa (H1):
Pelo menos uma média difere das demais.

O teste ANOVA responde:
"Existe evidência de diferença entre as médias dos grupos?"

Se p < 0,05:
- rejeitamos H0
- concluímos que pelo menos um grupo difere

Se p >= 0,05:
- não rejeitamos H0
- não há evidência suficiente de diferença entre as médias
""")


# ============================================================
# CÉLULA 6 – Ajuste do modelo
# O que esta célula faz:
# 1. Ajusta um modelo linear com tratamento como fator categórico.
# 2. Obtém os resíduos do modelo para checar premissas.
# ============================================================

modelo = ols('reducao_pressao ~ C(tratamento)', data=df).fit()
residuos = modelo.resid

print("Resumo curto do modelo ajustado:")
print(modelo.summary())


# ============================================================
# CÉLULA 7 – Verificação das premissas
# O que esta célula faz:
# 1. Testa normalidade dos resíduos (Shapiro-Wilk).
# 2. Testa homogeneidade das variâncias (Levene).
# 3. Mostra histograma e QQ-plot dos resíduos.
#
# Premissas clássicas da ANOVA:
# - independência das observações
# - normalidade dos resíduos
# - homogeneidade de variâncias
# ============================================================

print("TESTE DE SHAPIRO-WILK PARA OS RESÍDUOS")
shapiro_result = stats.shapiro(residuos)
print(shapiro_result)

print("\nTESTE DE LEVENE PARA HOMOGENEIDADE DE VARIÂNCIAS")
levene_result = stats.levene(
    df.loc[df['tratamento'] == 'Placebo', 'reducao_pressao'],
    df.loc[df['tratamento'] == 'Fármaco A', 'reducao_pressao'],
    df.loc[df['tratamento'] == 'Fármaco B', 'reducao_pressao'],
    df.loc[df['tratamento'] == 'Fármaco C', 'reducao_pressao']
)
print(levene_result)

print("""
INTERPRETAÇÃO DOS TESTES DE PREMISSAS:
- Shapiro-Wilk:
  H0 = resíduos seguem distribuição normal
  Se p > 0,05, não rejeitamos a normalidade

- Levene:
  H0 = variâncias dos grupos são iguais
  Se p > 0,05, não rejeitamos homogeneidade de variâncias
""")

fig, axes = plt.subplots(1, 2, figsize=(12, 5))

sns.histplot(residuos, kde=True, ax=axes[0], color='steelblue')
axes[0].set_title('Histograma dos resíduos')

sm.qqplot(residuos, line='45', ax=axes[1])
axes[1].set_title('QQ-plot dos resíduos')

plt.tight_layout()
plt.show()


# ============================================================
# CÉLULA 8 – Tabela ANOVA
# O que esta célula faz:
# 1. Gera a tabela ANOVA.
# 2. Explica o significado das colunas:
#    sum_sq, df, F, PR(>F)
# ============================================================

anova = sm.stats.anova_lm(modelo, typ=2)
print("TABELA ANOVA")
display(anova)

print("""
COMO INTERPRETAR A TABELA ANOVA

1) sum_sq  = soma de quadrados
   - Mede a variabilidade associada a cada fonte.
   - Em C(tratamento): variabilidade explicada pelo fator tratamento.
   - Em Residual: variabilidade não explicada (erro dentro dos grupos).

2) df = graus de liberdade
   - Para o fator: k - 1
   - Para o resíduo: N - k
   onde k = número de grupos; N = número total de observações

3) F = estatística F
   - É a razão entre a variabilidade entre grupos e a variabilidade dentro dos grupos.
   - Quanto maior o F, maior a evidência de que as médias não são todas iguais.

4) PR(>F) = p-valor
   - Probabilidade de observar um F tão extremo quanto o observado,
     assumindo que H0 é verdadeira.
   - Se p < 0,05: rejeitamos H0
   - Se p >= 0,05: não rejeitamos H0
""")

p_anova = anova.loc['C(tratamento)', 'PR(>F)']
F_anova = anova.loc['C(tratamento)', 'F']

print(f"Valor de F observado: {F_anova:.4f}")
print(f"Valor de p observado: {p_anova:.6f}")

if p_anova < 0.05:
    print("""
CONCLUSÃO DA ANOVA:
Como p < 0,05, rejeitamos a hipótese nula.
Existe evidência estatística de que pelo menos uma média difere entre os tratamentos.
""")
else:
    print("""
CONCLUSÃO DA ANOVA:
Como p >= 0,05, não rejeitamos a hipótese nula.
Não há evidência suficiente para afirmar diferença entre as médias dos tratamentos.
""")


