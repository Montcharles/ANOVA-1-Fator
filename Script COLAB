# ============================================================
# CÉLULA 13 – Função para gerar letras de Tukey
# O que esta célula faz:
# 1. Cria uma versão prática de agrupamento por letras.
# 2. Grupos que NÃO diferem podem compartilhar letras.
# 3. Grupos que diferem significativamente NÃO compartilham letras.
#
# Observação:
# Essa é uma implementação prática de compact letter display.
# ============================================================

def gerar_letras_tukey(tukey_df, medias_df, grupo_col='tratamento', media_col='mean'):
    grupos = medias_df.sort_values(media_col)[grupo_col].tolist()

    # matriz de significância: True = grupos diferem
    sig = pd.DataFrame(False, index=grupos, columns=grupos)

    for _, row in tukey_df.iterrows():
        g1 = row['group1']
        g2 = row['group2']
        rj = bool(row['reject'])
        sig.loc[g1, g2] = rj
        sig.loc[g2, g1] = rj

    letras_disponiveis = list("abcdefghijklmnopqrstuvwxyz")
    letras_grupos = {g: "" for g in grupos}
    conjuntos = []

    for g in grupos:
        colocado = False

        for i, conjunto in enumerate(conjuntos):
            # grupo pode entrar no conjunto se NÃO for diferente de ninguém ali
            pode_entrar = True
            for membro in conjunto:
                if sig.loc[g, membro] == True:
                    pode_entrar = False
                    break
            if pode_entrar:
                conjunto.append(g)
                letras_grupos[g] += letras_disponiveis[i]
                colocado = True

        if not colocado:
            conjuntos.append([g])
            letras_grupos[g] += letras_disponiveis[len(conjuntos)-1]

    # ajuste extra: se um grupo puder compartilhar letra com outro conjunto sem conflito, adiciona
    for g in grupos:
        for i, conjunto in enumerate(conjuntos):
            letra = letras_disponiveis[i]
            if letra in letras_grupos[g]:
                continue
            pode_entrar = True
            for membro in conjunto:
                if sig.loc[g, membro] == True:
                    pode_entrar = False
                    break
            if pode_entrar:
                letras_grupos[g] += letra

    return letras_grupos


# ============================================================
# CÉLULA 14 – Gerar letras de Tukey
# O que esta célula faz:
# 1. Ordena grupos pela média.
# 2. Atribui letras para o gráfico final.
# ============================================================

medias_plot = desc[['tratamento', 'mean', 'se', 'ic95_inf', 'ic95_sup']].copy()
medias_plot = medias_plot.sort_values('mean')

letras = gerar_letras_tukey(tukey_df, medias_plot, grupo_col='tratamento', media_col='mean')
medias_plot['letra_tukey'] = medias_plot['tratamento'].map(letras)

print("Tabela final com letras de Tukey:")
display(medias_plot.round(3))

print("""
INTERPRETAÇÃO DAS LETRAS DE TUKEY:
- Grupos com a mesma letra: não diferem estatisticamente entre si.
- Grupos com letras diferentes: diferem estatisticamente.
- Esse formato é muito usado em gráficos de artigos, relatórios e dissertações.
""")


# ============================================================
# CÉLULA 15 – Gráfico final para relatório
# O que esta célula faz:
# 1. Gera gráfico de barras com média e IC95%.
# 2. Adiciona letras de Tukey acima das barras.
# 3. Produz figura final pronta para relatório/artigo.
